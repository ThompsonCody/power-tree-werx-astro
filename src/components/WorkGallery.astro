---
import { Image } from "astro:assets";

import work1 from "../assets/work-1.png";
import work2 from "../assets/work-2.png";
import work3 from "../assets/work-3.png";
import work4 from "../assets/work-4.png";
import work5 from "../assets/work-5.png";

const shots = [
  { src: work1, alt: "Tree removal job on a rural property", tall: true },
  { src: work2, alt: "Equipment-assisted tree work and rigging" },
  { src: work3, alt: "Chipper and cleanup work" },
  { src: work4, alt: "Arborist climbing and technical removal" },
  { src: work5, alt: "Service area forest and landscape" },
];
---

<section class="section section--center">
  <div class="wrap">
    <h2>Recent Work</h2>
    <div class="work-grid">
      {shots.map((s, i) => (
        <figure class={`shot ${s.tall ? "shot--tall" : ""}`}>
          <button
            class="lightbox-trigger"
            data-index={i}
            data-src={s.src.src}
            data-alt={s.alt}
          >
            <Image src={s.src} alt={s.alt} loading="lazy" />
          </button>
        </figure>
      ))}
    </div>
  </div>
      <!-- LIGHTBOX -->
    <div id="lightbox" class="lightbox">
      <div class="lightbox-backdrop"></div>

      <div class="lightbox-content">
        <button class="lightbox-close">×</button>
        <button class="lightbox-prev">‹</button>

        <img id="lightbox-image" src="" alt="" />

        <button class="lightbox-next">›</button>
      </div>
    </div>

  </div>
  <script type="module" src="/scripts/lightbox.js"></script>
</section>