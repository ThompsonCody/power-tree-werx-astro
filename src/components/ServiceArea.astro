---
const KEY = import.meta.env.PUBLIC_GOOGLE_MAPS_KEY;

const locations = [
  { name: "Celista", lat: 50.94428878338736, lng: -119.3494946266158 },
  { name: "White Lake", lat: 50.8832096135161, lng: -119.29965833441462 },
  { name: "Sicamous", lat: 50.83882153226538, lng: -118.98757357903504 },
  { name: "Chase", lat: 50.82674871789868, lng: -119.69907887187028 },
  { name: "Canoe", lat: 50.75209156531621, lng: -119.2281204205039 },
  { name: "Salmon Arm", lat: 50.70211661284123, lng: -119.27820009065822 },
];
---

<section id="area" class="section">
  <div class="wrap">
    <h2 class="center">Service Area</h2>

    <div class="area-card">
      <div class="area-map">
        <div id="map" aria-label="Service area map"></div>
      </div>

      <ul class="area-list">
        {locations.map((l) => <li>{l.name}</li>)}
      </ul>
    </div>
  </div>

  <script is:inline define:vars={{ locations }}>
    // Google expects a global callback
    window.initMap = function initMap() {
      const center = { lat: 50.85, lng: -119.57 };

      const map = new google.maps.Map(document.getElementById("map"), {
        zoom: 9.5,
        center,
        disableDefaultUI: true,
        zoomControl: true,
      });

      locations.forEach((loc) => {
        new google.maps.Marker({
          position: { lat: loc.lat, lng: loc.lng },
          map,
          title: loc.name,
        });
      });
    };
  </script>

  {KEY && (
    <script
      async
      src={`https://maps.googleapis.com/maps/api/js?key=${KEY}&callback=initMap`}
    ></script>
  )}
</section>